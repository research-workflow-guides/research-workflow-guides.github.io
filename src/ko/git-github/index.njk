---
layout: layouts/base.njk
title: Git과 GitHub
description: Git과 GitHub 워크플로우를 위한 카테고리 홈.
lang: ko
pageClass: page-section
---
{% set pageUi = canonical.pageUi[page.url] %}
{% set breadcrumbs = pageUi.breadcrumbs %}
{% set grouped = canonical.groupedDocs.ko["git-github"] %}
<main class="content-shell">
  {% include "components/left-rail.njk" %}

  <article class="doc-content panel" data-pagefind-body>
    {% include "components/breadcrumbs.njk" %}

    <section class="doc-hero doc-hero-simple">
      <div>
        <h1>Git과 GitHub</h1>
        <p class="lead">project template이 로컬에서 동작하는 상태라면 여기서 시작합니다.</p>
      </div>
    </section>

    <section id="preparation" class="doc-section">
      <h2>준비</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in grouped.preparation %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">단계 {{ loop.index }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section id="first-github-workflow" class="doc-section">
      <h2>첫 GitHub 작업</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in grouped["first-github-workflow"] %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">단계 {{ loop.index + 2 }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section id="daily-workflow" class="doc-section">
      <h2>일상 작업</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in grouped["daily-workflow"] %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">주제 {{ loop.index }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section id="collaboration" class="doc-section">
      <h2>협업</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in grouped.collaboration %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">주제 {{ loop.index + 2 }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>
  </article>
</main>
