<!doctype html>
<html lang="{{ lang or 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@400;500;700&family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/site-assets/styles.css?v={{ build.assetVersion }}">
  </head>
  {% set currentPageMeta = canonical.pagesByUrl[page.url] %}
  {% set currentPageUi = canonical.pageUi[page.url] %}
  {% set currentLang = currentPageMeta.lang if currentPageMeta and currentPageMeta.lang != "root" else lang %}
  {% set currentSection = currentPageUi.activeSection if currentPageUi else activeSection %}
  <body class="{{ pageClass or '' }}{% if currentSection %} section--{{ currentSection }}{% endif %}" data-page-lang="{{ lang or '' }}">
    {% set currentLangSwitch = currentPageUi.langSwitch if currentPageUi else langSwitch %}
    <header class="site-header" data-pagefind-ignore="all">
      <div class="wrap site-header-inner">
        <a class="brand" href="/">{{ site.name }}</a>

        {% if navStyle == "legacy-en" %}
          <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-nav"
            data-menu-toggle
          >
            Menu
          </button>
          <nav id="primary-nav" class="site-nav" aria-label="Primary">
            {% for item in navigation.legacy.en %}
              <a
                href="{{ item.url }}"
                {% if currentSection == item.key %}aria-current="page"{% endif %}
              >
                {{ item.label }}
              </a>
            {% endfor %}
            {% if currentLangSwitch %}
              <a class="lang-switch" href="{{ currentLangSwitch.url }}">{{ currentLangSwitch.label }}</a>
            {% endif %}
          </nav>
        {% elif navStyle == "legacy-ko-section" %}
          <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-nav"
            data-menu-toggle
          >
            Menu
          </button>
          <nav id="primary-nav" class="site-nav" aria-label="Primary">
            {% for item in navigation.legacy.koSection %}
              <a
                href="{{ item.url }}"
                {% if currentSection == item.key %}aria-current="page"{% endif %}
              >
                {{ item.label }}
              </a>
            {% endfor %}
            {% if currentLangSwitch %}
              <a class="lang-switch" href="{{ currentLangSwitch.url }}">{{ currentLangSwitch.label }}</a>
            {% endif %}
          </nav>
        {% elif currentLang %}
          <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-nav"
            data-menu-toggle
          >
            Menu
          </button>
          <nav id="primary-nav" class="site-nav" aria-label="Primary">
            {% for section in navigation.sections %}
              <div class="nav-dropdown nav-section--{{ section.key }}">
                <a
                  href="{{ section.url[currentLang] }}"
                  {% if currentSection == section.key %}aria-current="page"{% endif %}
                >{{ section.title[currentLang] }}</a>
                <div class="dropdown-menu">
                  {% for docPage in section.pages[currentLang] %}
                    <a href="{{ docPage.url }}">{{ docPage.title }}</a>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
            {% if currentLangSwitch %}
              <a class="lang-switch" href="{{ currentLangSwitch.url }}">{{ currentLangSwitch.label }}</a>
            {% endif %}
          </nav>
        {% else %}
          <nav class="site-nav site-nav-root" aria-label="Primary">
            {% for language in navigation.languages %}
              <a href="{{ language.url }}">{{ language.label }}</a>
            {% endfor %}
          </nav>
        {% endif %}
      </div>
    </header>

    {{ content | safe }}

    <footer class="site-footer" data-pagefind-ignore="all">
      <div class="wrap footer-inner">
        <div>
          <p class="footer-brand">{{ site.name }}</p>
          {% set latestFooterDate = git.latestCommitDate or (updates.latest.date if updates.latest else null) %}
          {% if latestFooterDate %}
            <p class="footer-update">Latest update: {{ latestFooterDate }}</p>
          {% endif %}
        </div>
        <div class="footer-meta">
          <p>&copy; 2026 {{ site.authorLine }}</p>
          <a href="{{ site.oldVersionUrl }}">Old Version</a>
        </div>
      </div>
    </footer>

    <script src="/site-assets/app.js?v={{ build.assetVersion }}" defer></script>
  </body>
</html>
