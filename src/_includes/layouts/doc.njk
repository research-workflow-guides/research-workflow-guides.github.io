---
layout: layouts/base.njk
pageClass: page-doc
---
{% set currentPageUi = canonical.pageUi[page.url] %}
{% set breadcrumbs = currentPageUi.breadcrumbs if currentPageUi else breadcrumbs %}
{% set prevPage = currentPageUi.prevPage if currentPageUi else prevPage %}
{% set nextPage = currentPageUi.nextPage if currentPageUi else nextPage %}
<main class="content-shell">
  {% include "components/left-rail.njk" %}

  <article class="doc-content panel" data-pagefind-body>
    {% include "components/breadcrumbs.njk" %}

    <section class="doc-hero">
      <div>
        {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
        <h1>{{ title }}</h1>
        {% if lead %}<p class="lead">{{ lead | safe }}</p>{% endif %}
      </div>
      {% if meta %}
        <dl class="meta-list">
          {% for item in meta %}
            <div>
              <dt>{{ item.label }}</dt>
              <dd>{{ item.value }}</dd>
            </div>
          {% endfor %}
        </dl>
      {% endif %}
    </section>

    <div class="prose">
      {{ content | safe }}
    </div>

    {% if prevPage or nextPage %}
      <section class="page-nav">
        {% if prevPage %}
          <a class="nav-panel" href="{{ prevPage.url }}">
            <strong>{% if lang == "ko" %}Previous{% else %}Previous{% endif %}</strong>
            <span>{{ prevPage.title }}</span>
          </a>
        {% endif %}
        {% if nextPage %}
          <a class="nav-panel" href="{{ nextPage.url }}">
            <strong>{% if lang == "ko" %}Next{% else %}Next{% endif %}</strong>
            <span>{{ nextPage.title }}</span>
          </a>
        {% endif %}
      </section>
    {% endif %}
  </article>
</main>
