{% set pageUi = canonical.pageUi[page.url] %}
{% set breadcrumbs = pageUi.breadcrumbs %}
{% set docs = canonical.groupedDocs.en["start-here"].steps %}
<main class="content-shell">
  {% include "components/left-rail.njk" %}

  <article class="doc-content panel" data-pagefind-body>
    {% include "components/breadcrumbs.njk" %}

    <section class="doc-hero doc-hero-simple">
      <div>
        <p class="eyebrow">Getting Started</p>
        <h1>Start Here</h1>
        <p class="lead">Follow three steps to get your LaTeX environment running and complete your first successful build.</p>
      </div>
    </section>

    <section id="core-route" class="doc-section">
      <h2>Steps</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in docs %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">Step {{ doc.order }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section id="readiness" class="doc-section">
      <h2>Before moving on</h2>
      <div class="stack-list">
        <article class="stack-item">
          <h3>Follow the installation order</h3>
          <p>Install the distribution first, then the editor, then the starter project.</p>
        </article>
        <article class="stack-item">
          <h3>Start with one template</h3>
          <p>Getting a clean first build matters more than exploring different setup options.</p>
        </article>
        <article class="stack-item">
          <h3>Confirm the PDF before moving on</h3>
          <p>The next section assumes your compile loop is already working.</p>
        </article>
      </div>
    </section>

    <section class="callout-card">
      <p class="eyebrow">Next</p>
      <h2>After the first compile</h2>
      <p>Once the first build succeeds, move into the daily editing workflow in VS Code.</p>
      <a class="text-link" href="/en/writing-in-vs-code/">Go to Writing in VS Code</a>
    </section>
  </article>
</main>
