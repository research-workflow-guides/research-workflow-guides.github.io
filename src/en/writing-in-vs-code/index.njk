---
layout: layouts/base.njk
title: Work in VS Code
description: English category home for daily writing workflows in VS Code.
lang: en
pageClass: page-section
toc:
  - id: core-documents
    label: Main topics
  - id: optional-documents
    label: Optional topics
---
{% set pageUi = canonical.pageUi[page.url] %}
{% set breadcrumbs = pageUi.breadcrumbs %}
{% set docs = canonical.groupedDocs.en["writing-in-vs-code"]["main-topics"] %}
{% set optionalDocs = canonical.groupedDocs.en["writing-in-vs-code"]["optional-topics"] %}
<main class="content-shell">
  {% include "components/left-rail.njk" %}

  <article class="doc-content panel" data-pagefind-body>
    {% include "components/breadcrumbs.njk" %}

    <section class="doc-hero doc-hero-simple">
      <div>
        <p class="eyebrow">Part 2</p>
        <h1>Work in VS Code</h1>
        <p class="lead">Covers the edit, build, preview, and revision loop for daily work in VS Code.</p>
      </div>
    </section>

    <section id="core-documents" class="doc-section">
      <h2>Main topics</h2>
      <div class="feature-grid feature-grid-compact">
        {% for doc in docs %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">Topic {{ doc.order }}</p>
            <h3>{{ doc.title }}</h3>
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section id="optional-documents" class="doc-section">
      <h2>Optional topics</h2>
      <p class="subtle">Use this only when you need a review PDF for submission revisions.</p>
      <div class="feature-grid feature-grid-compact">
        {% for doc in optionalDocs %}
          <a class="feature-card panel" href="{{ doc.url }}">
            <p class="card-kicker">Optional</p>
            {% if doc.logo %}
              <img src="{{ doc.logo }}" alt="{{ doc.title }}" style="height:clamp(28px,4vw,44px);width:auto;max-width:100%;display:block;margin-bottom:0.75rem">
            {% else %}
              <h3>{{ doc.title }}</h3>
            {% endif %}
            <p>{{ doc.description }}</p>
          </a>
        {% endfor %}
      </div>
    </section>

    <section class="callout-card">
      <p class="eyebrow">Next</p>
      <h2>Then move to Git &amp; GitHub</h2>
      <p>Once the writing loop is stable, continue to repository and collaboration workflows.</p>
      <a class="text-link" href="/en/git-github/">Go to Git &amp; GitHub</a>
    </section>
  </article>
</main>
